generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExamRole {
  OWNER
  MEMBER
}

enum PlanItemKind {
  STUDY
  REVIEW
}

model User {
  id             String           @id @default(cuid())
  name           String
  email          String           @unique
  login          String?          @unique
  passwordHash   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  memberships    ExamMembership[]
  studySessions  StudySession[]
  questionLogs   QuestionLog[]
  studyPlanItems StudyPlanItem[]
}

model Exam {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String?
  examDate          DateTime?
  weeklyGoalMinutes Int              @default(300)
  reviewIntervals   String           @default("1,7,30")
  reviewMinutes     Int              @default(30)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  memberships       ExamMembership[]
  subjects          Subject[]
  studySessions     StudySession[]
  questionLogs      QuestionLog[]
  studyPlanItems    StudyPlanItem[]
  topics            Topic[]
}

model ExamMembership {
  id                String   @id @default(cuid())
  role              ExamRole @default(MEMBER)
  weeklyGoalMinutes Int?
  userId            String
  examId            String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam              Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([examId])
}

model Subject {
  id                String          @id @default(cuid())
  name              String
  color             String
  position          Int             @default(0)
  weeklyGoalMinutes Int?
  archivedAt        DateTime?
  examId            String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  exam              Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  studySessions     StudySession[]
  questionLogs      QuestionLog[]
  studyPlanItems    StudyPlanItem[]
  topics            Topic[]

  @@unique([examId, name])
  @@index([examId])
}

model StudySession {
  id              String   @id @default(cuid())
  studiedAt       DateTime @default(now())
  durationMinutes Int
  notes           String?
  userId          String
  examId          String
  subjectId       String
  topicId         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic           Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId, studiedAt])
  @@index([examId, studiedAt])
  @@index([subjectId])
  @@index([topicId])
}

model QuestionLog {
  id                String   @id @default(cuid())
  answeredAt        DateTime @default(now())
  questionsAnswered Int
  correctAnswers    Int
  notes             String?
  userId            String
  examId            String
  subjectId         String
  topicId           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam              Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject           Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic             Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId, answeredAt])
  @@index([examId, answeredAt])
  @@index([subjectId])
  @@index([topicId])
}

model StudyPlanItem {
  id               String       @id @default(cuid())
  kind             PlanItemKind @default(STUDY)
  title            String
  scheduledFor     DateTime
  estimatedMinutes Int
  notes            String?
  completedAt      DateTime?
  userId           String
  examId           String
  subjectId        String
  topicId          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam             Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject          Subject      @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  topic            Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId, scheduledFor])
  @@index([examId, scheduledFor])
  @@index([subjectId])
  @@index([topicId])
}

model Topic {
  id             String          @id @default(cuid())
  name           String
  description    String?
  position       Int             @default(0)
  archivedAt     DateTime?
  examId         String
  subjectId      String
  parentId       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parent         Topic?          @relation("TopicHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Topic[]         @relation("TopicHierarchy")
  studySessions  StudySession[]
  questionLogs   QuestionLog[]
  studyPlanItems StudyPlanItem[]

  @@index([examId])
  @@index([subjectId, parentId, position])
  @@index([parentId])
}
