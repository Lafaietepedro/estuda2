generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExamRole {
  OWNER
  MEMBER
}

enum PlanItemKind {
  STUDY
  REVIEW
}

model User {
  id             String           @id @default(cuid())
  name           String
  email          String           @unique
  login          String?          @unique
  passwordHash   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  memberships    ExamMembership[]
  studySessions  StudySession[]
  questionLogs   QuestionLog[]
  studyPlanItems StudyPlanItem[]
}

model Exam {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String?
  examDate          DateTime?
  weeklyGoalMinutes Int              @default(300)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  memberships       ExamMembership[]
  subjects          Subject[]
  studySessions     StudySession[]
  questionLogs      QuestionLog[]
  studyPlanItems    StudyPlanItem[]
}

model ExamMembership {
  id                String   @id @default(cuid())
  role              ExamRole @default(MEMBER)
  weeklyGoalMinutes Int?
  userId            String
  examId            String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam              Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([examId])
}

model Subject {
  id                String          @id @default(cuid())
  name              String
  color             String
  position          Int             @default(0)
  weeklyGoalMinutes Int?
  archivedAt        DateTime?
  examId            String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  exam              Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  studySessions     StudySession[]
  questionLogs      QuestionLog[]
  studyPlanItems    StudyPlanItem[]

  @@unique([examId, name])
  @@index([examId])
}

model StudySession {
  id              String   @id @default(cuid())
  studiedAt       DateTime @default(now())
  durationMinutes Int
  notes           String?
  userId          String
  examId          String
  subjectId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([userId, studiedAt])
  @@index([examId, studiedAt])
  @@index([subjectId])
}

model QuestionLog {
  id                String   @id @default(cuid())
  answeredAt        DateTime @default(now())
  questionsAnswered Int
  correctAnswers    Int
  notes             String?
  userId            String
  examId            String
  subjectId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam              Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject           Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([userId, answeredAt])
  @@index([examId, answeredAt])
  @@index([subjectId])
}

model StudyPlanItem {
  id               String       @id @default(cuid())
  kind             PlanItemKind @default(STUDY)
  title            String
  scheduledFor     DateTime
  estimatedMinutes Int
  notes            String?
  completedAt      DateTime?
  userId           String
  examId           String
  subjectId        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam             Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject          Subject      @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  @@index([userId, scheduledFor])
  @@index([examId, scheduledFor])
  @@index([subjectId])
}
